<Page x:Class="FT_ProgramWPF.View.DownloadingView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FT_ProgramWPF.View"
      xmlns:vm="clr-namespace:FT_ProgramWPF.ViewModel"
      d:DataContext="{d:DesignInstance Type=vm:DownloadingViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DownloadingView">

    <ScrollViewer>
        <StackPanel Orientation="Vertical">
            <StackPanel.Resources>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Margin" Value="0, 25, 0, 0"/>
                </Style>
                <!--<Style TargetType="{x:Type Grid}">
                    <Setter Property="Margin" Value="0, 25, 0, 0"/>
                </Style>-->
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Margin" Value="0, 25, 0, 0"/>
                </Style>
            </StackPanel.Resources>
            <Button HorizontalAlignment="Left"
                    Command="{Binding GetServerFilesCommand}"
                    MinHeight="30">
                <TextBlock Text="Get Server Files"
                           Margin="0"
                           Padding="5"/>
            </Button>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0">
                    <TextBlock Text="Date"
                               Margin="10,0,0,0"/>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="1">
                    <TextBlock Text="Name"/>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="3">
                    <TextBlock Text="Download"/>
                </Border>

            </Grid>
            <ItemsControl ItemsSource="{Binding Files}">
                <!--<ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>

                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>-->
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:Name="FileInfoTemplate">
                        <Border Padding="10"
                                BorderBrush="LightGray"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Grid.Row="0"
                                           VerticalAlignment="Center"
                                           Text="{Binding Data}"/>
                                
                                <TextBlock Grid.Column="1"
                                           Grid.Row="0"
                                           VerticalAlignment="Center"
                                           Text="{Binding Name}"/>
                                
                                <Button Command="{Binding DownloadCommand}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="0"
                                        MinHeight="30"
                                        Grid.Column="2">
                                    <TextBlock Text="Download"
                                               Margin="0"
                                               Padding="5"/>
                                </Button>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
