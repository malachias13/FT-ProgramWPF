<Page x:Class="FT_ProgramWPF.View.HostingView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FT_ProgramWPF.View"
      xmlns:vm="clr-namespace:FT_ProgramWPF.ViewModel"
      xmlns:m="clr-namespace:FT_ProgramWPF.Model"
      xmlns:elem="clr-namespace:FT_ProgramWPF.Elements"
      d:DataContext="{d:DesignInstance Type=vm:HostingViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HostingView">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Hosting logs"
                   Foreground="White"
                   FontSize="25"
                   HorizontalAlignment="Center"/>

        <RichTextBox Grid.Row="1"
                     elem:RichTextBoxBehavior.ItemsSource="{Binding LogEntries}"
                     IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="1">
            <RichTextBox.Document>
                <FlowDocument TextAlignment="Left"
                              PagePadding="0"/>
            </RichTextBox.Document>
        </RichTextBox>

        <ScrollViewer
                     Grid.Row="2"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"       
                     Margin="10"
                     MinHeight="0">
            <ItemsControl ItemsSource="{Binding LogEntries}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" 
                                   Margin="2"
                                   TextWrapping="WrapWithOverflow"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>


        <StackPanel Orientation="Horizontal"
                    Grid.Row="3"
                    Margin="0,0, 10, 10"
                    HorizontalAlignment="Right">
            
            <Button 
                    MinHeight="20"
                    MaxHeight="45"
                    MinWidth="100"
                    Width="100"
                    Command="{Binding ServerToggleCommand}"
                    Content="{Binding ServerToggleTxt}"
                    Background="{Binding ServerToggleBtnColor}"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    HorizontalAlignment="Center"/>
        </StackPanel>



    </Grid>
   
</Page>
