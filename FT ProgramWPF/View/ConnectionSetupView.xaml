<Page x:Class="FT_ProgramWPF.View.ConnectionSetupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FT_ProgramWPF.View"
      xmlns:vm="clr-namespace:FT_ProgramWPF.ViewModel"
      d:DataContext="{d:DesignInstance Type=vm:ConnectionSetupViewModel}"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConnectionSetupView">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Margin="10">
        <StackPanel Orientation="Vertical">
            <Image Source="/Resources/cloud_data_download_icon.png"
                   MaxWidth="128"/>
            <TextBlock Text="FT Program"
                       HorizontalAlignment="Center"/>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition MinHeight="50"/>
                    <RowDefinition MinHeight="25"/>
                    <RowDefinition MinHeight="25"/>
                    <RowDefinition MinHeight="45"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Vertical"
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            MinWidth="10"
                            MinHeight="10"
                            Margin="0,10">
                    <TextBlock Text="{Binding OutputPath}"
                               Margin="0,10"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               MinHeight="10"/>
                    <Button MinHeight="30"
                            Command="{Binding PickFolderCommand}">
                        <TextBlock Text="Output folder"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="1"
                           TextAlignment="Center"
                           Text="invalided URL"
                           Foreground="Red"
                           Visibility="{Binding ErrorMessageVisiblity}"/>

                <TextBox Grid.Row="2"
                         
                         Text="{Binding IPAddressStr, Mode=TwoWay}"
                         Margin="50,0"/>

                <StackPanel Grid.Row="3"
                            Orientation="Horizontal"
                            MinHeight="10" HorizontalAlignment="Center"
                            Margin="0,15,0,0">
                    <Button Command="{Binding HostCommand}"
                            IsEnabled="{Binding HostButtonEnable}"
                            Margin="0,0,10, 0"
                            MinWidth="80">
                        <TextBlock Text="Host"/>
                    </Button>

                    <Button MinWidth="80"
                            Command="{Binding JoinCommand}"
                            IsEnabled="{Binding JoinButtonEnable}">
                        <TextBlock Text="Join"/>
                    </Button>

                </StackPanel>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
